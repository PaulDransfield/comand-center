# .env.example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
#
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── SUPABASE ──────────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY

# ── ANTHROPIC ──────────────────────────────────────────────────────
# From: console.anthropic.com → API Keys
# ⚠️  ROTATE THIS KEY before deploying — previous key was potentially exposed
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── STRIPE ────────────────────────────────────────────────────────
# From: stripe.com → Developers → API keys
# Use sk_test_ prefix for development, sk_live_ for production
STRIPE_SECRET_KEY=sk_test_...
# From: Stripe → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# From: Stripe → Products → your price → Price ID
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# ── EMAIL ──────────────────────────────────────────────────────────
# From: resend.com → API Keys
RESEND_API_KEY=re_...

# ── SECURITY ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
CREDENTIAL_ENCRYPTION_KEY=64_hex_characters_here
# Used to hash personnummer (Swedish ID) — separate from encryption key
PERSONNUMMER_HMAC_SECRET=another_64_hex_characters_here
# Protects the /api/cron/* endpoints from being called by anyone other than Vercel
CRON_SECRET=any_random_string_here
# Admin TOTP secret — generate with an authenticator app setup tool
ADMIN_TOTP_SECRET=BASE32_ENCODED_SECRET

# ── FORTNOX ───────────────────────────────────────────────────────
# From: developer.fortnox.se (apply for developer account — takes 2-4 weeks)
FORTNOX_CLIENT_ID=your_fortnox_client_id
FORTNOX_CLIENT_SECRET=your_fortnox_client_secret

# ── MONITORING (optional) ─────────────────────────────────────────
# From: api.slack.com → Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# For SMS critical alerts via Twilio (optional)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+46...
ADMIN_PHONE_NUMBER=+46701234567

# ── ANALYTICS (optional) ──────────────────────────────────────────
# From: posthog.com → Project settings → API keys
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── APP ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
