# CommandCenter Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Enhanced API Schema Discovery Agent Environment Variables
# Required for Enhanced API Discovery Agent
ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Claude Haiku 4.5
CRON_SECRET=your_secure_cron_secret_here       # For cron job authentication

# Admin Authentication
ADMIN_SECRET=admin123          # Password for admin panel access

# Supabase Configuration (with NEXT_PUBLIC_ prefix as required by the code)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ── Stripe Price IDs ──────────────────────────────────────────────
# 4 plans × monthly/annual + 1 add-on = 9 IDs total. Get each from
# Stripe Dashboard → Products → click the Product → copy the price_id
# (starts with price_). Annual price = monthly × 10 (2 months free).
# Plans: lib/stripe/config.ts is the source of truth for tier names + amounts.
#
# If any of these are unset, /api/stripe/checkout returns a clear 500
# naming the missing variable — won't silently fall back to wrong plan
# (FIXES §0gg, Sprint 2 Task 7).

# Founding Customer — 995 kr/mo · 9 950 kr/yr (10 spots, locked 24 mo)
STRIPE_PRICE_FOUNDING=price_...
STRIPE_PRICE_FOUNDING_ANNUAL=price_...

# Solo — 1 995 kr/mo · 19 950 kr/yr
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...

# Group — 4 995 kr/mo · 49 950 kr/yr
STRIPE_PRICE_GROUP=price_...
STRIPE_PRICE_GROUP_ANNUAL=price_...

# Chain — 9 995 kr/mo · 99 950 kr/yr
STRIPE_PRICE_CHAIN=price_...
STRIPE_PRICE_CHAIN_ANNUAL=price_...

# AI Booster add-on — 299 kr/mo, +100 AI queries/day
STRIPE_PRICE_AI_ADDON=price_...

# Email Configuration
RESEND_API_KEY=your_resend_api_key

# Security
CREDENTIAL_ENCRYPTION_KEY=64_hex_characters_generated_with_crypto_randomBytes

# Fortnox Integration
FORTNOX_CLIENT_ID=your_fortnox_client_id
FORTNOX_CLIENT_SECRET=your_fortnox_client_secret

# Monitoring (optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Sentry error monitoring (optional in dev, required in prod)
# Get the DSN from Sentry dashboard → Settings → Client Keys (DSN)
# Leave unset in dev/preview to keep errors local only.
NEXT_PUBLIC_SENTRY_DSN=https://<public-key>@oXXXXX.ingest.de.sentry.io/<project-id>
# Used at build time only for source-map upload — never needed at runtime.
# SENTRY_AUTH_TOKEN=sntrys_...

# AI global kill-switch: total Claude spend (USD) across ALL orgs in last 24 h.
# Exceeding this pauses every AI call company-wide. Default: 50.
# MAX_DAILY_GLOBAL_USD=50

# Ops inbox that receives the daily AI usage digest (08:00 UTC cron)
# OPS_EMAIL=ops@comandcenter.se

# App URL
NEXT_PUBLIC_APP_URL=https://your-app-url.vercel.app

# Note: Replace all placeholder values with your actual credentials
# For local development, you can use test values
# The application will need these values to function properly