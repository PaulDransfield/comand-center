# CommandCenter Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Enhanced API Schema Discovery Agent Environment Variables
# Required for Enhanced API Discovery Agent
ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Claude Haiku 4.5
CRON_SECRET=your_secure_cron_secret_here       # For cron job authentication

# Admin Authentication
ADMIN_SECRET=admin123          # Password for admin panel access

# Supabase Configuration (with NEXT_PUBLIC_ prefix as required by the code)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_STARTER=your_starter_price_id
STRIPE_PRICE_PRO=your_pro_price_id

# Email Configuration
RESEND_API_KEY=your_resend_api_key

# Security
CREDENTIAL_ENCRYPTION_KEY=64_hex_characters_generated_with_crypto_randomBytes

# Fortnox Integration
FORTNOX_CLIENT_ID=your_fortnox_client_id
FORTNOX_CLIENT_SECRET=your_fortnox_client_secret

# Monitoring (optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url

# App URL
NEXT_PUBLIC_APP_URL=https://your-app-url.vercel.app

# Note: Replace all placeholder values with your actual credentials
# For local development, you can use test values
# The application will need these values to function properly